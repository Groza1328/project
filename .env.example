# Локальный запуск из папки Хост (профиль local)
SPRING_PROFILES_ACTIVE=local

# --- На Railway эти переменные подставляются автоматически при привязке PostgreSQL ---
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# DATABASE_URL=postgresql://user:pass@host:port/db
# PORT=8080

# --- Почта (задайте в Variables сервиса на Railway) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-service@gmail.com
MAIL_PASSWORD=app-password-from-google
MAIL_FROM=your-service@gmail.com
